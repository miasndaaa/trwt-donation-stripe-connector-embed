{
  "version": 2,
  "builds": [
    { "src": "api/create-checkout.js", "use": "@vercel/node" },
    { "src": "api/webhook.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/api/create-checkout",
      "dest": "/api/create-checkout.js",
      "methods": ["POST", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type"
      }
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js",
      "methods": ["POST"]
    }
  ]
}
